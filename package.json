{
  "name": "back-spim",
  "version": "1.0.0",
  "description": "API REST para gestão de ordens de serviço, equipamentos, usuários, prazos de atendimento e histórico operacional.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "db:migrate": "tsx src/scripts/runMigrations.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:ordens": "tsx src/scripts/seedOrdensDemo.ts",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand __test__/__tests-unitarios__",
    "test:integration": "npm run test:integration:docker",
    "test:integration:jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.cjs --runInBand",
    "test:integration:docker": "bash scripts/test-integration.sh",
    "load:smoke": "bash scripts/test-load.sh smoke",
    "load:steady": "bash scripts/test-load.sh steady",
    "load:spike": "bash scripts/test-load.sh spike"
  },
  "keywords": [
    "ordem-servico",
    "manutencao",
    "typeorm",
    "express",
    "postgresql"
  ],
  "author": "Rodrigo da Silva Bezerra, Patrese Emiron Barbosa de Souza, Daniel Valdivino Silva",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "overrides": {
    "brace-expansion": "^2.0.3",
    "path-to-regexp": "^8.4.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
