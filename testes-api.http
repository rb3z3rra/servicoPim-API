@baseUrl = http://localhost:9090

### =========================================================
### GUIA DE TESTE MANUAL DA API
### =========================================================
###
### Fluxo recomendado:
### 1. Verificar se a API está no ar
### 2. Fazer login com um SUPERVISOR já criado no banco
### 3. Criar um SOLICITANTE e um TECNICO
### 4. Fazer login com cada perfil
### 5. Criar equipamento com SUPERVISOR
### 6. Criar OS com SOLICITANTE
### 7. Atribuir técnico com SUPERVISOR
### 8. Atualizar status e concluir com TECNICO
### 9. Consultar histórico com SUPERVISOR ou TECNICO
###
### Observações importantes:
### - POST /usuarios exige token de SUPERVISOR
### - o primeiro SUPERVISOR precisa existir no banco antes
### - POST /ordens-servico NÃO recebe solicitanteId; a API usa o usuário logado
### - DELETE /usuarios/:id desativa o usuário; não remove fisicamente

### =========================================================
### HEALTHCHECK
### =========================================================

### 1. Verificar se a API subiu
GET {{baseUrl}}/health

### =========================================================
### AUTENTICAÇÃO
### =========================================================

### 2. Login como SUPERVISOR
# @name loginSupervisor
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@servicopim.com",
  "senha": "senha123"
}

###
@supervisorToken = {{loginSupervisor.response.body.accessToken}}
@supervisorRefreshToken = {{loginSupervisor.response.body.refreshToken}}
@supervisorId = {{loginSupervisor.response.body.usuario.id}}

### 3. Refresh do token do SUPERVISOR
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{supervisorRefreshToken}}"
}

### =========================================================
### USUÁRIOS
### =========================================================

### 4. Criar um SOLICITANTE
# @name criarSolicitante
POST {{baseUrl}}/usuarios
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "nome": "Solicitante Manual",
  "email": "solicitante.manual@servicopim.com",
  "senha": "senha123",
  "perfil": "SOLICITANTE",
  "setor": "Operacao",
  "ativo": true
}

###
@solicitanteId = {{criarSolicitante.response.body.id}}

### 5. Criar um TECNICO
# @name criarTecnico
POST {{baseUrl}}/usuarios
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "nome": "Tecnico Manual",
  "email": "tecnico.manual@servicopim.com",
  "senha": "senha123",
  "perfil": "TÉCNICO",
  "setor": "Manutencao",
  "ativo": true
}

###
@tecnicoId = {{criarTecnico.response.body.id}}

### 6. Listar usuários
GET {{baseUrl}}/usuarios
Authorization: Bearer {{supervisorToken}}

### 7. Buscar usuário por id
GET {{baseUrl}}/usuarios/{{solicitanteId}}
Authorization: Bearer {{supervisorToken}}

### 8. Atualizar o próprio SUPERVISOR
PUT {{baseUrl}}/usuarios/{{supervisorId}}
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "nome": "Administrador Atualizado",
  "setor": "TI"
}

### 9. Desativar usuário
DELETE {{baseUrl}}/usuarios/{{solicitanteId}}
Authorization: Bearer {{supervisorToken}}

### =========================================================
### LOGIN DOS PERFIS CRIADOS
### =========================================================

### 10. Login como SOLICITANTE
# @name loginSolicitante
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "solicitante.manual@servicopim.com",
  "senha": "senha123"
}

###
@solicitanteToken = {{loginSolicitante.response.body.accessToken}}

### 11. Login como TECNICO
# @name loginTecnico
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "tecnico.manual@servicopim.com",
  "senha": "senha123"
}

###
@tecnicoToken = {{loginTecnico.response.body.accessToken}}

### =========================================================
### EQUIPAMENTOS
### =========================================================

### 12. Criar equipamento com SUPERVISOR
# @name criarEquipamento
POST {{baseUrl}}/equipamentos
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "codigo": "EQP-MANUAL-001",
  "nome": "Torno Mecânico",
  "tipo": "Industrial",
  "localizacao": "Setor A",
  "fabricante": "IndustriaX",
  "modelo": "TX-500",
  "ativo": true
}

###
@equipamentoId = {{criarEquipamento.response.body.id}}

### 13. Listar equipamentos
GET {{baseUrl}}/equipamentos
Authorization: Bearer {{supervisorToken}}

### 14. Buscar equipamento por id
GET {{baseUrl}}/equipamentos/{{equipamentoId}}
Authorization: Bearer {{supervisorToken}}

### 15. Atualizar equipamento
PUT {{baseUrl}}/equipamentos/{{equipamentoId}}
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "localizacao": "Setor B",
  "modelo": "TX-500 REV 2"
}

### =========================================================
### ORDENS DE SERVIÇO
### =========================================================

### 16. Criar OS com SOLICITANTE
# @name criarOS
POST {{baseUrl}}/ordens-servico
Authorization: Bearer {{solicitanteToken}}
Content-Type: application/json

{
  "equipamentoId": {{equipamentoId}},
  "tipo_manutencao": "PREVENTIVA",
  "prioridade": "ALTA",
  "descricao_falha": "O equipamento está fazendo um barulho metálico muito alto durante as rotações."
}

###
@osId = {{criarOS.response.body.id}}

### 17. Listar OS
GET {{baseUrl}}/ordens-servico
Authorization: Bearer {{solicitanteToken}}

### 18. Buscar OS por id
GET {{baseUrl}}/ordens-servico/{{osId}}
Authorization: Bearer {{solicitanteToken}}

### 19. Atribuir técnico com SUPERVISOR
PATCH {{baseUrl}}/ordens-servico/{{osId}}/atribuir-tecnico
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "tecnicoId": "{{tecnicoId}}"
}

### 20. Alterar status para AGUARDANDO_PECA com TECNICO
PATCH {{baseUrl}}/ordens-servico/{{osId}}/status
Authorization: Bearer {{tecnicoToken}}
Content-Type: application/json

{
  "status": "AGUARDANDO_PECA"
}

### 21. Voltar status para EM_ANDAMENTO com TECNICO
PATCH {{baseUrl}}/ordens-servico/{{osId}}/status
Authorization: Bearer {{tecnicoToken}}
Content-Type: application/json

{
  "status": "EM_ANDAMENTO"
}

### 22. Concluir OS com TECNICO
PATCH {{baseUrl}}/ordens-servico/{{osId}}/concluir
Authorization: Bearer {{tecnicoToken}}
Content-Type: application/json

{
  "descricao_servico": "Substituição de rolamento e reaperto da estrutura.",
  "pecas_utilizadas": "Rolamento XYZ-100",
  "horas_trabalhadas": 3
}

### =========================================================
### HISTÓRICO DE OS
### =========================================================

### 23. Listar todos os históricos
GET {{baseUrl}}/historico-os
Authorization: Bearer {{supervisorToken}}

### 24. Listar históricos por ordem de serviço
GET {{baseUrl}}/historico-os/ordem-servico/{{osId}}
Authorization: Bearer {{supervisorToken}}

### 25. Listar históricos por usuário
GET {{baseUrl}}/historico-os/usuario/{{supervisorId}}
Authorization: Bearer {{supervisorToken}}

### =========================================================
### CENÁRIOS DE ERRO ÚTEIS
### =========================================================

### 26. Login com senha errada
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@servicopim.com",
  "senha": "senha_errada"
}

### 27. Acesso sem token
GET {{baseUrl}}/usuarios

### 28. Criar usuário com perfil sem permissão
POST {{baseUrl}}/usuarios
Authorization: Bearer {{solicitanteToken}}
Content-Type: application/json

{
  "nome": "Usuario Sem Permissao",
  "email": "sem.permissao@servicopim.com",
  "senha": "senha123",
  "perfil": "SOLICITANTE",
  "setor": "Teste"
}

### 29. Concluir OS sem técnico atribuído
POST {{baseUrl}}/ordens-servico
Authorization: Bearer {{solicitanteToken}}
Content-Type: application/json

{
  "equipamentoId": {{equipamentoId}},
  "tipo_manutencao": "CORRETIVA",
  "prioridade": "BAIXA",
  "descricao_falha": "Teste de erro sem técnico atribuído."
}

###
@osSemTecnicoId = {{$lastResponse.body.id}}

### 30. Tentar concluir a OS sem técnico
PATCH {{baseUrl}}/ordens-servico/{{osSemTecnicoId}}/concluir
Authorization: Bearer {{tecnicoToken}}
Content-Type: application/json

{
  "descricao_servico": "Tentativa inválida",
  "horas_trabalhadas": 1
}
